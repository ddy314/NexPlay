fn build_rows(cards: &[UiMediaCardData]) -> Vec<UiMediaRow> {
    let empty = empty_slint_card();
    cards
        .chunks(5)
        .map(|chunk| UiMediaRow {
            card0: chunk
                .first()
                .map(to_slint_card)
                .unwrap_or_else(|| empty.clone()),
            card1: chunk
                .get(1)
                .map(to_slint_card)
                .unwrap_or_else(|| empty.clone()),
            card2: chunk
                .get(2)
                .map(to_slint_card)
                .unwrap_or_else(|| empty.clone()),
            card3: chunk
                .get(3)
                .map(to_slint_card)
                .unwrap_or_else(|| empty.clone()),
            card4: chunk
                .get(4)
                .map(to_slint_card)
                .unwrap_or_else(|| empty.clone()),
            show0: !chunk.is_empty(),
            show1: chunk.len() > 1,
            show2: chunk.len() > 2,
            show3: chunk.len() > 3,
            show4: chunk.len() > 4,
        })
        .collect::<Vec<_>>()
}

