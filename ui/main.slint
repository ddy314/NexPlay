import { Button, LineEdit, ListView, TextEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    width: 1000px;
    height: 720px;
    title: "Slint Bangumi";

    in-out property <int> active_tab: 0;
    in-out property <string> media_path_input;
    in property <[string]> media_items;
    in-out property <string> selected_info;
    in-out property <string> logs;
    in-out property <string> scan_progress;
    in-out property <string> settings_summary;

    callback add_media_path(string);
    callback scan_library();
    callback select_media(int);
    callback play_selected_media();
    callback save_progress();
    callback clear_progress();
    callback load_danmaku();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            spacing: 8px;
            Button {
                text: root.active_tab == 0 ? "Home *" : "Home";
                clicked => { root.active_tab = 0; }
            }
            Button {
                text: root.active_tab == 1 ? "Media Library *" : "Media Library";
                clicked => { root.active_tab = 1; }
            }
            Button {
                text: root.active_tab == 2 ? "Settings *" : "Settings";
                clicked => { root.active_tab = 2; }
            }
        }

        if root.active_tab == 0 : VerticalBox {
            spacing: 8px;

            Text {
                text: "Home";
                font-size: 20px;
                font-weight: 700;
            }

            Text {
                text: "Scan progress: " + root.scan_progress;
            }

            HorizontalBox {
                spacing: 8px;
                Button {
                    text: "Scan Library";
                    clicked => { root.scan_library(); }
                }
                Button {
                    text: "Open Media Library";
                    clicked => { root.active_tab = 1; }
                }
                Button {
                    text: "Open Settings";
                    clicked => { root.active_tab = 2; }
                }
            }

            Text { text: "Runtime log"; font-weight: 700; }
            TextEdit {
                height: 520px;
                text: root.logs;
                read-only: true;
            }
        }

        if root.active_tab == 1 : VerticalBox {
            spacing: 8px;

            Text {
                text: "Media Library";
                font-size: 20px;
                font-weight: 700;
            }

            HorizontalBox {
                spacing: 8px;
                LineEdit {
                    text <=> root.media_path_input;
                    placeholder-text: "Local media folder path";
                }
                Button {
                    text: "Add Folder";
                    clicked => { root.add_media_path(root.media_path_input); }
                }
                Button {
                    text: "Scan";
                    clicked => { root.scan_library(); }
                }
            }

            HorizontalBox {
                spacing: 12px;

                VerticalBox {
                    Text { text: "Videos"; font-weight: 700; }
                    ListView {
                        height: 420px;
                        for item[index] in root.media_items : Button {
                            text: item;
                            clicked => { root.select_media(index); }
                        }
                    }
                }

                VerticalBox {
                    Text { text: "Selected video"; font-weight: 700; }
                    TextEdit {
                        height: 280px;
                        text: root.selected_info;
                        read-only: true;
                    }
                    HorizontalBox {
                        spacing: 8px;
                        Button {
                            text: "Play";
                            clicked => { root.play_selected_media(); }
                        }
                        Button {
                            text: "Load Danmaku";
                            clicked => { root.load_danmaku(); }
                        }
                    }
                    HorizontalBox {
                        spacing: 8px;
                        Button {
                            text: "Save Test Progress";
                            clicked => { root.save_progress(); }
                        }
                        Button {
                            text: "Clear Progress";
                            clicked => { root.clear_progress(); }
                        }
                    }
                }
            }

            Text { text: "Scan progress: " + root.scan_progress; }
        }

        if root.active_tab == 2 : VerticalBox {
            spacing: 8px;

            Text {
                text: "Settings";
                font-size: 20px;
                font-weight: 700;
            }

            Text { text: "Media paths"; font-weight: 700; }
            HorizontalBox {
                spacing: 8px;
                LineEdit {
                    text <=> root.media_path_input;
                    placeholder-text: "Add local media folder";
                }
                Button {
                    text: "Add";
                    clicked => { root.add_media_path(root.media_path_input); }
                }
            }

            Text { text: "Current configuration"; font-weight: 700; }
            TextEdit {
                height: 220px;
                text: root.settings_summary;
                read-only: true;
            }

            Text { text: "Runtime log"; font-weight: 700; }
            TextEdit {
                height: 300px;
                text: root.logs;
                read-only: true;
            }
        }
    }
}
